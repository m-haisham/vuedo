{
  "name": "example-vue",
  "version": "1.0.0",
  "private": true,
  "description": "Example Elysia consumer of @pandaf/vue",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '**/*.timestamp-*.mjs' src/server.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.15",
    "@pandaf/vue": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "elysia": "^1.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.4.0",
    "concurrently": "^10.0.3",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.0"
  }
}
