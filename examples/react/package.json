{
  "name": "example-react",
  "version": "1.0.0",
  "private": true,
  "description": "Example Elysia consumer of @vuedo/react",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '**/*.timestamp-*.mjs' src/server.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.15",
    "@vuedo/react": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "elysia": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^10.0.3",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
