{
  "name": "@pandaf/vue",
  "version": "0.1.1",
  "description": "Vue SSR → PDF generation using @pandaf/core",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js",
      "require": "./dist/vite-plugin.js",
      "default": "./dist/vite-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-haisham/pandaf.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/m-haisham/pandaf/issues"
  },
  "homepage": "https://github.com/m-haisham/pandaf#readme",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vue",
    "pdf",
    "pdf-generation",
    "vue-ssr",
    "gotenberg",
    "puppeteer",
    "vite"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@pandaf/core": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.4.0",
    "vue": "^3.4.0",
    "vue-component-type-helpers": "^3.3.7"
  },
  "peerDependencies": {
    "vite": "^5.0.0",
    "puppeteer": "^23.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "puppeteer-core": "^23.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
