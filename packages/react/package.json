{
  "name": "@vuedo/react",
  "version": "0.1.0",
  "description": "React SSR → PDF generation using @vuedo/core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@vuedo/core": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0",
    "puppeteer": "^23.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "puppeteer-core": "^23.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
