{
  "name": "@pandaf/core",
  "version": "0.1.0",
  "description": "Framework-agnostic HTML → PDF generation primitives",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-haisham/vuedo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/m-haisham/vuedo/issues"
  },
  "homepage": "https://github.com/m-haisham/vuedo#readme",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pdf",
    "pdf-generation",
    "html-to-pdf",
    "gotenberg",
    "puppeteer",
    "ssr",
    "vite"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": "^5.0.0",
    "puppeteer": "^23.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "puppeteer-core": "^23.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
