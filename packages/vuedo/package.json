{
  "name": "@hshm/vuedo",
  "version": "0.1.0",
  "description": "Vue SSR → PDF generation (Gotenberg or local Chromium) as an embeddable library",
  "type": "module",
  "bin": {
    "vuedo": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@tailwindcss/node": "^4.0.0",
    "@tailwindcss/oxide": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.4.0",
    "vue": "^3.4.0",
    "vue-component-type-helpers": "^3.3.7"
  },
  "peerDependencies": {
    "vite": "^5.0.0",
    "puppeteer": "^23.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "puppeteer-core": "^23.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
