{
  "name": "vuedo",
  "version": "1.0.0",
  "description": "PDF generation service — a consumer of @hshm/vuedo",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n css,api \"tailwindcss -i ./assets/app.css -o ./dist/app.css --watch\" \"tsx watch --ignore \\\"**/*.timestamp-*.mjs\\\" src/server.ts\"",
    "build:css": "tailwindcss -i ./assets/app.css -o ./dist/app.css",
    "build": "vite build && pnpm build:css",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["pdf", "vue", "ssr", "gotenberg", "elysia"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "@sinclair/typebox": ">=0.34.0 <1"
    }
  },
  "dependencies": {
    "@hshm/vuedo": "workspace:*",
    "@elysiajs/node": "^1.4.5",
    "elysia": "^1.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.4.0",
    "concurrently": "^9.0.0",
    "pdf-parse": "^1.1.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0",
    "vitest": "^1.6.0"
  }
}
