{
  "name": "vuedo",
  "version": "1.0.0",
  "private": true,
  "description": "Vue SSR → PDF generation — monorepo",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "@sinclair/typebox": ">=0.34.0 <1"
    }
  },
  "scripts": {
    "dev": "pnpm --filter example-vue dev",
    "build": "pnpm --filter example-vue build",
    "start": "pnpm --filter example-vue start",
    "typecheck": "pnpm --filter example-vue typecheck",
    "test": "pnpm -r test",
    "infra:up": "pnpm --filter example-vue infra:up",
    "infra:down": "pnpm --filter example-vue infra:down"
  }
}
