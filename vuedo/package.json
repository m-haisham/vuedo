{
  "name": "vuedo",
  "version": "1.0.0",
  "description": "Enterprise PDF Generation Microservice (Vue SSR + Gotenberg)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore \"**/*.timestamp-*.mjs\" src/dev-server.ts",
    "build": "vite build --ssr src/entry-server.ts --outDir dist",
    "start": "tsx src/server-prod.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["pdf", "vue", "ssr", "gotenberg", "elysia"],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "@sinclair/typebox": ">=0.34.0 <1"
    }
  },
  "dependencies": {
    "@elysiajs/node": "^1.0.0",
    "elysia": "^1.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/server-renderer": "^3.4.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^1.6.0"
  }
}
