# Dependencies
node_modules/

# Build output (root consumer + library package)
dist/
dist-server/
packages/*/dist/
examples/*/dist/

# Test / coverage artifacts
coverage/
*.tsbuildinfo

# Temporary verification / scratch dirs
.verify/
.verify-dist/
.tmp-dist/
.single/

# Library build: transient vite config written next to dist/cli.js
packages/*/.vuedo-build-*.ts

# Dev-only artifacts (CSS, types, etc.) emitted by @hshm/vuedo
.vuedo/

# Generated template-props types (emitted by @hshm/vuedo on build / `vuedo types)
examples/*/src/generated/

# Turbo
.turbo/

# Logs
*.log

# OS / editor
.DS_Store
.vscode/
.idea/

# Generated PDFs (e.g. test output)
*.pdf
